+// createOpenAITokenProvider creates a standard OpenAI-compatible HTTP provider
+// using a token credential from the auth store as the API key.
+func createOpenAITokenProvider(cfg *config.ModelConfig) (LLMProvider, error) {
+	cred, err := getCredential("openai")
+	if err != nil {
+		return nil, fmt.Errorf("loading auth credentials: %w", err)
+	}
+	if cred == nil {
+		return nil, fmt.Errorf("no credentials for openai. Run: picoclaw auth login --provider openai")
+	}
+	apiBase := cfg.APIBase
+	if apiBase == "" {
+		apiBase = getDefaultAPIBase("openai")
+	}
+	return NewHTTPProviderWithMaxTokensFieldAndRequestTimeout(
+		cred.AccessToken,
+		apiBase,
+		cfg.Proxy,
+		cfg.MaxTokensField,
+		cfg.RequestTimeout,
+		cfg.ExtraBody,
+	), nil
+}
