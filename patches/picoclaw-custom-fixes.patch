+func TestTranscribeAudioInMessage_RemovesSuccessfulAudioMedia(t *testing.T) {
+	al, _, _, _, cleanup := newTestAgentLoop(t)
+	defer cleanup()
+
+	store := media.NewFileMediaStore()
+	al.SetMediaStore(store)
+	al.SetTranscriber(&fakeTranscriber{text: "turn on the pump"})
+
+	dir := t.TempDir()
+	audioPath := filepath.Join(dir, "note.ogg")
+	if err := os.WriteFile(audioPath, []byte("fake-audio"), 0o644); err != nil {
+		t.Fatal(err)
+	}
+	audioRef, err := store.Store(audioPath, media.MediaMeta{Filename: "voice.ogg"}, "scope-a")
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	txtPath := filepath.Join(dir, "note.txt")
+	if err := os.WriteFile(txtPath, []byte("hello"), 0o644); err != nil {
+		t.Fatal(err)
+	}
+	fileRef, err := store.Store(txtPath, media.MediaMeta{Filename: "note.txt"}, "scope-a")
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	msg := bus.InboundMessage{
+		Content: "[voice]",
+		Media:   []string{audioRef, fileRef},
+	}
+
+	got, status := al.transcribeAudioInMessage(context.Background(), msg)
+	if !status.hadAudio {
+		t.Fatal("expected hadAudio = true")
+	}
+	if !status.usableTranscript {
+		t.Fatal("expected usableTranscript = true")
+	}
+	if got.Content != "turn on the pump" {
+		t.Fatalf("content = %q", got.Content)
+	}
+	if len(got.Media) != 1 || got.Media[0] != fileRef {
+		t.Fatalf("media = %#v, want only non-audio ref", got.Media)
+	}
+}
